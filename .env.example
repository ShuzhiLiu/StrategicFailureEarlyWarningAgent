# Copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.

# ── LLM Backend ────────────────────────────────────────────────
# SFEWA uses the OpenAI-compatible protocol, which works with:
#   - Local vLLM server (default, recommended for reproducibility)
#   - Ollama with a compatible model
#   - OpenAI API (gpt-4o, gpt-4-turbo)
#   - Anthropic via an OpenAI-compatible proxy
#
# Default setup: Qwen3.6-27B (full precision) on local vLLM.
# Earlier baseline used Qwen3.5-27B-GPTQ-Int4 — both are documented in
# README.md so the model swap's effect is auditable.
# To swap in another model, change MODEL + BASE_URL below.

DEFAULT_LLM_PROVIDER=vllm
DEFAULT_LLM_MODEL=Qwen/Qwen3.6-27B
DEFAULT_BASE_URL=http://localhost:8000/v1
# DEFAULT_API_KEY=sk-...        # only needed for OpenAI/hosted endpoints

# ── Python Environment (optional) ──────────────────────────────
# Absolute path to the Python interpreter used by helper scripts.
# Leave unset to use the active virtualenv.
# PYTHON_EXECUTABLE=/path/to/your/python

# ── EDINET API (optional, for Japanese filings) ───────────────
# Register at https://disclosure2dl.edinet-fsa.go.jp/guide/static/register
# Without this key, Honda/Toyota runs fall back to web-only evidence
# and score variance increases.
EDINET_API_KEY=
